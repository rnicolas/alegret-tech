---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

const posts = (await getCollection("thinking-ca", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Pensaments — Roger N. Alegret"
  description="Textos sobre sistemes encastats, arquitectura, interoperabilitat i estratègia."
>
  <Header lang="ca" />

  <main class="section">
    <div class="page">
      <p class="eyebrow">Pensaments</p>
      <h1>Pensaments</h1>
      <p>
        Textos i arguments sobre sistemes encastats, interoperabilitat, comportament
        del sistema i arquitectura de producte.
      </p>

      <div class="article-list" style="margin-top: 2rem;">
        {posts.map((post) => (
          <a class="article-card card" href={`/ca/pensaments/${post.data.slug}/`}>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>