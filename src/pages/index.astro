---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Roger" description="Embedded systems, architecture, and strategy.">
  <main class="language-home">
    <div class="language-card">
      <h1>Roger</h1>
      <p>Choose language / Tria idioma</p>

      <div class="language-links">
        <a href="/en/" onclick="localStorage.setItem('lang','en')">English</a>
        <a href="/ca/" onclick="localStorage.setItem('lang','ca')">Català</a>
      </div>
    </div>
  </main>

  <script is:inline>
    const saved = localStorage.getItem("lang");

    if (saved) {
      window.location.replace(saved === "ca" ? "/ca/" : "/en/");
    } else {
      const lang = (navigator.language || "").toLowerCase();
      const detected = lang.startsWith("ca") ? "ca" : "en";

      localStorage.setItem("lang", detected);
      window.location.replace("/" + detected + "/");
    }
  </script>
</BaseLayout>