---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PositioningBlock from "../../components/PositioningBlock.astro";

const latestPosts = (await getCollection("thinking-en", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<BaseLayout
  title="Roger — Embedded systems, architecture, and strategy"
  description="Thoughts and projects on embedded systems, interoperability, and product architecture."
>
  <Header lang="en" />

  <main>
    <section class="hero">
      <div class="page">
        <div class="hero-copy">
          <p class="eyebrow">Embedded systems · Architecture · Strategy</p>
          <h1>Transforming connected products into coherent systems.</h1>
          <p>
            My focus is not connectivity alone, but the layer above it:
            behavior, diagnostics, interoperability, and architecture.
          </p>
        </div>
      </div>
    </section>

    <PositioningBlock
      label="Positioning"
      quote="The field network is not the system. The behavior and the data model are."
      body="Connectivity only becomes valuable when the rest of the stack can reason about devices cleanly."
    />

    <section class="section">
      <div class="page">
        <p class="eyebrow">Latest writing</p>
        <h2>Recent thinking</h2>

        <div class="article-list" style="margin-top: 2rem;">
          {latestPosts.map((post) => (
            <a class="article-card card" href={`/en/thinking/${post.data.slug}/`}>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="page">
        <p class="eyebrow">Sections</p>
        <div class="article-list">
          <a class="article-card card" href="/en/thinking/">
            <h3>Thinking</h3>
            <p>Essays and arguments on connected systems, integration, and architecture.</p>
          </a>

          <a class="article-card card" href="/en/projects/">
            <h3>Projects</h3>
            <p>Selected projects, systems, and applied technical work.</p>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>