---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../../layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("thinking-en", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const catalanPosts = await getCollection("thinking-ca");
const alternate = catalanPosts.find(
  (entry) => entry.data.translationKey === post.data.translationKey
);

const { Content } = await render(post);
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  lang="en"
  alternateUrl={alternate ? `/ca/pensaments/${alternate.data.slug}/` : undefined}
>
  <Content />
</ArticleLayout>