---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  lang: "en" | "ca";
  alternateUrl?: string;
}

const { title, description, lang, alternateUrl } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header lang={lang} />

  <main class="section">
    <div class="page">
      <p class="eyebrow">{lang === "en" ? "Thinking" : "Pensaments"}</p>
      <h1>{title}</h1>

      {alternateUrl && (
        <p style="margin-top: -0.5rem; margin-bottom: 2rem;">
          <a href={alternateUrl}>
            {lang === "en" ? "Read this in Català" : "Read this in English"}
          </a>
        </p>
      )}

      <article class="card article-body">
        <slot />
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>